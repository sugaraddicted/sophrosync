{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ReportingDb": "Host=postgres;Port=5432;Database=sophrosync_reporting;Username=svc_reporting"
  },
  "Keycloak": {
    "Authority": "https://keycloak:8080/realms/sophrosync",
    "Audience": "sophrosync-gateway"
  },
  "ServiceUrls": {
    "ClientService": "http://clients-service:8080/",
    "ScheduleService": "http://schedule-service:8080/",
    "NotesService": "http://notes-service:8080/",
    "ConsentService": "http://consent-service:8080/"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
