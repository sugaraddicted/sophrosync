{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/sophrosync",
    "Audience": "sophrosync-gateway"
  },
  "ReverseProxy": {
    "Clusters": {
      "clients-cluster": {
        "Destinations": { "clients-service": { "Address": "http://localhost:5001/" } }
      },
      "schedule-cluster": {
        "Destinations": { "schedule-service": { "Address": "http://localhost:5002/" } }
      },
      "notes-cluster": {
        "Destinations": { "notes-service": { "Address": "http://localhost:5003/" } }
      },
      "documents-cluster": {
        "Destinations": { "documents-service": { "Address": "http://localhost:5004/" } }
      },
      "audit-cluster": {
        "Destinations": { "audit-service": { "Address": "http://localhost:5005/" } }
      },
      "consent-cluster": {
        "Destinations": { "consent-service": { "Address": "http://localhost:5006/" } }
      },
      "notifications-cluster": {
        "Destinations": { "notifications-service": { "Address": "http://localhost:5007/" } }
      },
      "reporting-cluster": {
        "Destinations": { "reporting-service": { "Address": "http://localhost:5008/" } }
      }
    }
  }
}
