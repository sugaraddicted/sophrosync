{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "https://keycloak:8080/realms/sophrosync",
    "Audience": "sophrosync-gateway"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "clients-route": {
        "ClusterId": "clients-cluster",
        "Match": { "Path": "/api/clients/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "schedule-route": {
        "ClusterId": "schedule-cluster",
        "Match": { "Path": "/api/appointments/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "notes-route": {
        "ClusterId": "notes-cluster",
        "Match": { "Path": "/api/notes/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "documents-route": {
        "ClusterId": "documents-cluster",
        "Match": { "Path": "/api/documents/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": { "Path": "/api/audit/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "notification-prefs-route": {
        "ClusterId": "notifications-cluster",
        "Match": { "Path": "/api/notification-preferences/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "consent-templates-route": {
        "ClusterId": "consent-cluster",
        "Match": { "Path": "/api/consent-templates/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "consent-requests-route": {
        "ClusterId": "consent-cluster",
        "Match": { "Path": "/api/consent-requests/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "reports-route": {
        "ClusterId": "reporting-cluster",
        "Match": { "Path": "/api/reports/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "internal-notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": { "Path": "/internal/notifications/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "Metadata": { "internal": "true" }
      },
      "internal-consent-route": {
        "ClusterId": "consent-cluster",
        "Match": { "Path": "/internal/consent/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "Metadata": { "internal": "true" }
      },
      "internal-notes-route": {
        "ClusterId": "notes-cluster",
        "Match": { "Path": "/internal/notes/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "Metadata": { "internal": "true" }
      }
    },
    "Clusters": {
      "clients-cluster": {
        "Destinations": {
          "clients-service": { "Address": "http://clients-service:8080/" }
        }
      },
      "schedule-cluster": {
        "Destinations": {
          "schedule-service": { "Address": "http://schedule-service:8080/" }
        }
      },
      "notes-cluster": {
        "Destinations": {
          "notes-service": { "Address": "http://notes-service:8080/" }
        }
      },
      "documents-cluster": {
        "Destinations": {
          "documents-service": { "Address": "http://documents-service:8080/" }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "audit-service": { "Address": "http://audit-service:8080/" }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "notifications-service": { "Address": "http://notifications-service:8080/" }
        }
      },
      "consent-cluster": {
        "Destinations": {
          "consent-service": { "Address": "http://consent-service:8080/" }
        }
      },
      "reporting-cluster": {
        "Destinations": {
          "reporting-service": { "Address": "http://reporting-service:8080/" }
        }
      }
    }
  }
}
