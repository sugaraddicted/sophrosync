# =============================================================
# Sophrosync — Development Secrets Template
# Copy this file to .env and fill in values.
# .env is gitignored and must NEVER be committed.
# =============================================================

# --- PostgreSQL superuser (used by Docker init) ---
POSTGRES_PASSWORD=change_me

# --- Per-service DB passwords (must match what init.sh creates) ---
CLIENTS_DB_PASSWORD=change_me
CONSENT_DB_PASSWORD=change_me
NOTES_DB_PASSWORD=change_me
NOTIFICATIONS_DB_PASSWORD=change_me
REPORTING_DB_PASSWORD=change_me
SCHEDULE_DB_PASSWORD=change_me

# --- Keycloak admin ---
KC_ADMIN_PASSWORD=change_me

# --- ASP.NET Core connection strings (loaded via launchSettings envFile) ---
# These override appsettings.Development.json when running services locally.
ConnectionStrings__ClientsDb=Host=localhost;Port=5432;Database=sophrosync_clients;Username=svc_clients;Password=change_me
ConnectionStrings__ConsentDb=Host=localhost;Port=5432;Database=sophrosync_consent;Username=svc_consent;Password=change_me
ConnectionStrings__NotesDb=Host=localhost;Port=5432;Database=sophrosync_notes;Username=svc_notes;Password=change_me
ConnectionStrings__NotificationsDb=Host=localhost;Port=5432;Database=sophrosync_notifications;Username=svc_notifications;Password=change_me
ConnectionStrings__ReportingDb=Host=localhost;Port=5432;Database=sophrosync_reporting;Username=svc_reporting;Password=change_me
ConnectionStrings__ScheduleDb=Host=localhost;Port=5432;Database=sophrosync_schedule;Username=svc_schedule;Password=change_me
